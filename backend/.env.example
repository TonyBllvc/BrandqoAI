DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/brandqoai
JWT_SECRET=change-me-in-production
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development # change to "production" during deployment

# WhatsApp Business Cloud API (set these in real deployments)
# WHATSAPP_VERIFY_TOKEN=your-verify-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_ACCESS_TOKEN=your-long-lived-access-token

# AI Providers (required for content generation)
# AI_PROVIDER can be "mistral" (default, cheaper) or "claude" (premium)
AI_PROVIDER=mistral

# Mistral 7B via Together AI (~$0.003 per 1K tokens)
# Required if AI_PROVIDER=mistral
TOGETHER_API_KEY=your-together-ai-api-key

# Claude Sonnet via Anthropic (~$0.003 per 1K tokens input)
# Required if AI_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stable Diffusion image generation (optional, used for image prompts)
REPLICATE_API_KEY=your-replicate-api-key
